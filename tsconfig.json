{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@shared-api/*": ["../Api_AppMicarandayo/*"]
    }
  },
  "include": [
